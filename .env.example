# Example environment variables for running the forecasting pipeline.
# Copy to .env and fill in values. Do NOT commit real credentials.

# SQL Server / ODBC settings
SQL_DRIVER="SQL Server"
SQL_SERVER="your_server_name"
SQL_DATABASE="your_database_name"
TRUSTED_CONNECTION=yes  # set to 'no' if using SQL UID/PWD
# If TRUSTED_CONNECTION is no, set:
# SQL_UID=your_user
# SQL_PWD=your_password

# Path to your SQL query file (relative to repo root or absolute path)
SQL_PATH=query.sql

# Forecast horizon (months)
FORECAST_HORIZON=13
